#!/bin/bash

count="$(
    hyprctl clients -j 2>/dev/null |
        jq '[.[] | select(
            .workspace.name == "special:minimized"
            or .workspace.name == "minimized"
            or ((.workspace.special // false) and (.workspace.name | contains("minimized")))
        )] | length' 2>/dev/null
)"

if [ -z "$count" ]; then
    count=0
fi

class=""
if [ "$count" -gt 0 ] 2>/dev/null; then
    class="has-windows"
fi

printf '{"text":"▾ %s","tooltip":"Minimized windows: %s","class":"%s"}\n' "$count" "$count" "$class"
